// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
    "edit_predictions": {
        "provider": "copilot",
    },
    "base_keymap": "VSCode",
    "icon_theme": "VSCode Icons for Zed (Dark Official Icons)",
    // "soft_wrap": "editor_width",
    "agent": {
        "play_sound_when_agent_done": false,
        "default_profile": "write",
        "default_model": {
            "provider": "copilot_chat",
            "model": "claude-haiku-4.5",
        },
        "model_parameters": [],
    },
    "theme": "Bluloco Dark Italic",
    "experimental.theme_overrides": {
        "version_control.added": "#00ff00",
        "version_control.deleted": "#ff0000",
        "terminal.background": "#212233ff",
        "terminal.foreground": "#f8f8f2",
        // Panel/sidebar background
        "panel.background": "#1a1a1a",
        "syntax": {
            "constant.comment.todo": {
                "color": "#FFBD2BFF",
                "background_color": "#FFBD2B1A",
                "font_weight": 600,
            },
            "string.comment.fixme": {
                "color": "#F44747FF",
                "background_color": "#F447471A",
                "font_weight": 600,
            },
            "comment.hack": {
                "color": "#3794FFFF",
                "background_color": "#3794FF12",
                "font_style": "italic",
                "font_weight": 500,
            },
            "comment.note": {
                "color": "#50A14FFF",
                "background_color": "#50A14F12",
                "font_style": "italic",
                "font_weight": 500,
            },
            "comment.error": {
                "color": "#CA1243FF",
                "background_color": "#CA12431A",
                "font_weight": 700,
            },
        },
    },
    "vim_mode": true,
    "ui_font_size": 14,
    "buffer_font_size": 16.0,
    "buffer_font_weight": 450,
    "buffer_font_features": {
        "calt": true,
    },
    "toolbar": {
        "breadcrumbs": false,
        "quick_actions": false,
    },
    "project_panel": {
        // "button": false,
        "entry_spacing": "standard",
    },
    "tabs": {
        "file_icons": true,
    },
    "autosave": "on_focus_change",
    "buffer_font_family": "CaskaydiaCove Nerd Font",
    "vertical_scroll_margin": 10,
    "relative_line_numbers": "enabled",
    "show_whitespaces": "all",
    "extend_comment_on_newline": false,
    "terminal": {
        "scroll_multiplier": 2,
    },
    "lsp": {
        "golangci-lint": {
            "initialization_options": {
                "command": [
                    "golangci-lint",
                    "run",
                    "--output.json.path",
                    "stdout",
                    "--show-stats=false",
                    "--output.text.path=",
                ],
            },
        },
    },
    "languages": {
        "YAML": {
            "indent_guides": {
                "coloring": "indent_aware",
                "background_coloring": "indent_aware"
            },
            "tab_size": 2
        },
        "Go": {
            "language_servers": [
                "gopls",
                "golangci-lint"
            ],
        },
    },
    "diagnostics": {
        "button": true,
        "include_warnings": true,
        "inline": {
            "enabled": true,
        },
    },
    "context_servers": {
        "mcp-server-context7": {
            "enabled": true,
            "settings": {
                "context7_api_key": "",
            },
        },
    },
    "wsl_connections": [
        {
            "distro_name": "Debian",
            "user": null,
            "projects": [
                {
                    "paths": [
                        "/home/ab_dullah"
                    ],
                },
                {
                    "paths": [
                        "/home/ab_dullah/workspace/yunex/yv/varia-rpm/varia-rpm-backend/./",
                    ],
                },
            ],
        },
    ],
}
